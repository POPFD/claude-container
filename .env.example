# Copy to .env and adjust. `.env` is gitignored.

# Session name advertised to claude.ai/code for Remote Control.
DEVBOX_NAME=devbox

# Memory cap for the devbox container (docker `mem_limit` format).
MEM_LIMIT=8g

# Hard ceiling on number of processes inside devbox.
PIDS_LIMIT=1024

# Upstream resolver the firewall sidecar forwards allowlisted queries
# to. Must be a single IP; pick a resolver you trust. Cloudflare 1.1.1.1
# and Google 8.8.8.8 are common defaults.
DNS_UPSTREAM=1.1.1.1

# Forward to DNS_UPSTREAM over DoT (TCP 853) instead of cleartext UDP 53.
# Closes on-path query leaks — without this, every allowlisted DNS
# query (and its response, including the IPs that then get programmed
# into the egress ipset) is visible to and tamperable by anyone between
# the container host and the upstream resolver. Set to 0 only if your
# upstream resolver does not support DoT (1.1.1.1 and 8.8.8.8 both do).
DNS_UPSTREAM_TLS=1

# Host path bind-mounted to /workspace inside devbox. Relative to the
# compose file.
WORKSPACE_PATH=./workspace

# Prevents `uv` from phoning home for self-update checks. Read-only
# rootfs would make self-update fail anyway; this silences the noise.
UV_NO_UPDATE_CHECK=1

# Documentation-only reminder: cargo is configured to work offline
# after the first fetch. Set a registry index timeout here if needed,
# otherwise leave unset. See the README.
# CARGO_NET_OFFLINE_AFTER=
